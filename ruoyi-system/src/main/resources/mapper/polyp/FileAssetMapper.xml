<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.polyp.mapper.FileAssetMapper">

    <resultMap id="FileAssetResult" type="FileAsset">
        <result property="fileId" column="file_id"/>
        <result property="bizType" column="biz_type"/>
        <result property="originName" column="origin_name"/>
        <result property="extName" column="ext_name"/>
        <result property="mimeType" column="mime_type"/>
        <result property="sizeBytes" column="size_bytes"/>
        <result property="storePath" column="store_path"/>
        <result property="fileUrl" column="file_url"/>
        <result property="sha256" column="sha256"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insertFileAsset" parameterType="FileAsset" useGeneratedKeys="true" keyProperty="fileId">
        insert into file_asset
        (biz_type, origin_name, ext_name, mime_type, size_bytes, store_path, file_url, sha256, create_by, create_time)
        values
        (#{bizType}, #{originName}, #{extName}, #{mimeType}, #{sizeBytes}, #{storePath}, #{fileUrl}, #{sha256}, #{createBy}, #{createTime})
    </insert>

    <select id="selectFileAssetByFileId" parameterType="Long" resultMap="FileAssetResult">
        select file_id, biz_type, origin_name, ext_name, mime_type, size_bytes, store_path, file_url, sha256, create_by, create_time
        from file_asset
        where file_id = #{fileId}
    </select>

</mapper>
