<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.medical.system.mapper.HisPolypDetailMapper">

    <resultMap type="HisPolypDetail" id="HisPolypDetailResult">
        <result property="polypId"    column="polyp_id"    />
        <result property="resultId"    column="result_id"    />
        <result property="polypIndex"    column="polyp_index"    />
        <result property="confidence"    column="confidence"    />
        <result property="sizeMm"    column="size_mm"    />
        <result property="position"    column="position"    />
        <result property="bboxX"    column="bbox_x"    />
        <result property="bboxY"    column="bbox_y"    />
        <result property="bboxWidth"    column="bbox_width"    />
        <result property="bboxHeight"    column="bbox_height"    />
        <result property="classification"    column="classification"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectHisPolypDetailVo">
        select polyp_id, result_id, polyp_index, confidence, size_mm, position, bbox_x, bbox_y, bbox_width, bbox_height, classification, create_time
        from his_polyp_detail
    </sql>

    <select id="selectHisPolypDetailList" parameterType="HisPolypDetail" resultMap="HisPolypDetailResult">
        <include refid="selectHisPolypDetailVo"/>
        <where>
            <if test="resultId != null "> and result_id = #{resultId}</if>
            <if test="polypIndex != null "> and polyp_index = #{polypIndex}</if>
            <if test="position != null  and position != ''"> and position = #{position}</if>
        </where>
        order by polyp_index asc
    </select>

    <select id="selectHisPolypDetailByResultId" parameterType="Long" resultMap="HisPolypDetailResult">
        <include refid="selectHisPolypDetailVo"/>
        where result_id = #{resultId}
        order by polyp_index asc
    </select>

    <select id="selectHisPolypDetailByPolypId" parameterType="Long" resultMap="HisPolypDetailResult">
        <include refid="selectHisPolypDetailVo"/>
        where polyp_id = #{polypId}
    </select>

    <insert id="insertHisPolypDetail" parameterType="HisPolypDetail" useGeneratedKeys="true" keyProperty="polypId">
        insert into his_polyp_detail
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="resultId != null">result_id,</if>
            <if test="polypIndex != null">polyp_index,</if>
            <if test="confidence != null">confidence,</if>
            <if test="sizeMm != null">size_mm,</if>
            <if test="position != null">position,</if>
            <if test="bboxX != null">bbox_x,</if>
            <if test="bboxY != null">bbox_y,</if>
            <if test="bboxWidth != null">bbox_width,</if>
            <if test="bboxHeight != null">bbox_height,</if>
            <if test="classification != null">classification,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="resultId != null">#{resultId},</if>
            <if test="polypIndex != null">#{polypIndex},</if>
            <if test="confidence != null">#{confidence},</if>
            <if test="sizeMm != null">#{sizeMm},</if>
            <if test="position != null">#{position},</if>
            <if test="bboxX != null">#{bboxX},</if>
            <if test="bboxY != null">#{bboxY},</if>
            <if test="bboxWidth != null">#{bboxWidth},</if>
            <if test="bboxHeight != null">#{bboxHeight},</if>
            <if test="classification != null">#{classification},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateHisPolypDetail" parameterType="HisPolypDetail">
        update his_polyp_detail
        <trim prefix="SET" suffixOverrides=",">
            <if test="resultId != null">result_id = #{resultId},</if>
            <if test="polypIndex != null">polyp_index = #{polypIndex},</if>
            <if test="confidence != null">confidence = #{confidence},</if>
            <if test="sizeMm != null">size_mm = #{sizeMm},</if>
            <if test="position != null">position = #{position},</if>
            <if test="bboxX != null">bbox_x = #{bboxX},</if>
            <if test="bboxY != null">bbox_y = #{bboxY},</if>
            <if test="bboxWidth != null">bbox_width = #{bboxWidth},</if>
            <if test="bboxHeight != null">bbox_height = #{bboxHeight},</if>
            <if test="classification != null">classification = #{classification},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where polyp_id = #{polypId}
    </update>

    <delete id="deleteHisPolypDetailByPolypId" parameterType="Long">
        delete from his_polyp_detail where polyp_id = #{polypId}
    </delete>

    <delete id="deleteHisPolypDetailByPolypIds" parameterType="String">
        delete from his_polyp_detail where polyp_id in
        <foreach item="polypId" collection="array" open="(" separator="," close=")">
            #{polypId}
        </foreach>
    </delete>

    <delete id="deleteHisPolypDetailByResultId" parameterType="Long">
        delete from his_polyp_detail where result_id = #{resultId}
    </delete>
</mapper>
